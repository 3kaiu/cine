TMDB_API_KEY=replace_with_your_tmdb_api_key

# FNOS host paths
CINE_DATA_DIR=/vol1/docker/cine/data
CINE_MEDIA_DIR=/vol1/media

# Host port exposed by docker compose
CINE_PORT=3000

# Backend configuration
RUST_LOG=cine=info,axum=info
CINE_MEDIA_DIRECTORIES=["/media"]
CINE_ENABLE_PLUGINS=false
CINE_ENABLE_CACHE_WARMUP=true
